// ============================================================================
// NEXUS TRADING INDICATOR - Unified SMC Trading System
// ============================================================================
// Version: 1.0.0
// Modules: Market Structure, Triple EMA, Sessions, SMC Features, ChoCH/BOS,
//          FVG, Liquidity Swings, Candlestick Patterns, MTF Bias Table, Alerts
// ============================================================================

//@version=6
indicator("Nexus Trading Indicator", shorttitle="NEXUS", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ============================================================================
//                          MODULE TOGGLES
// ============================================================================

show_market_structure = input.bool(true, "Market Structure (HH/HL/LH/LL)", group="Module Toggles", tooltip="Show zigzag swing structure with Higher High, Higher Low, Lower High, Lower Low labels")
show_ema              = input.bool(true, "Triple EMA (50/100/200)", group="Module Toggles", tooltip="Plot three Exponential Moving Averages on the chart")
show_sessions         = input.bool(true, "Trading Sessions", group="Module Toggles", tooltip="Show New York, London, and Asia session time zones with dividers")
show_smc              = input.bool(true, "SMC Features", group="Module Toggles", tooltip="Show Smart Money Concepts: swing structure, equal highs/lows, MTF levels, and premium/discount zones")
show_choch_bos        = input.bool(true, "ChoCH / BOS", group="Module Toggles", tooltip="Show Change of Character and Break of Structure labels when price breaks swing levels")
show_fvg              = input.bool(true, "Fair Value Gaps (FVG)", group="Module Toggles", tooltip="Show imbalance zones where price gapped over a candle body")
show_liq              = input.bool(true, "Liquidity Swings", group="Module Toggles", tooltip="Show swing pivot levels and detect when they are swept by price")
show_candle_patterns  = input.bool(true, "Candlestick Patterns", group="Module Toggles", tooltip="Detect and label reversal and continuation candlestick patterns")
show_confluence_table = input.bool(true, "Confluence Table", group="Module Toggles", tooltip="Show the multi-timeframe confluence scoring table")

// --- Confluence Settings ---
conf_show_details    = input.bool(true, "Show Details", group="Confluence", tooltip="Show individual factor rows. Disable to show only Direction and Score.")
conf_tbl_position    = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group="Confluence", tooltip="Table position on the chart")
conf_tbl_size        = input.string("Small", "Text Size", options=["Tiny", "Small", "Normal"], group="Confluence", tooltip="Text size for the confluence table")
conf_alert_threshold = input.int(5, "Alert Threshold", minval=1, maxval=7, group="Confluence", tooltip="Alert when confluence score reaches this level")

// ============================================================================
//                        SHARED CONSTANTS
// ============================================================================

BULLISH = 1
BEARISH = -1

// --- Colors ---
COLOR_BULL        = #22ab94
COLOR_BEAR        = #f7525f
COLOR_NEUTRAL     = #878b94
COLOR_TRANSPARENT = color.new(color.white, 100)
COLOR_TABLE_BG    = #1e222d  // Dark table background - works on both themes
COLOR_TABLE_BORDER = #363a45  // Subtle border color
COLOR_DISCOUNT    = #79c1f1
COLOR_PREMIUM     = #f19579

// --- Magic Numbers ---
SMC_MAX_ARRAY_SIZE = 10000 // Max bars stored for MTF level calculations
SES_ATR_PERIOD     = 14    // ATR period for session overlap detection
SES_OVERLAP_MULT   = 0.3   // ATR multiplier for session overlap threshold
SMC_ATR_PERIOD     = 200   // ATR period for swing measurement and zone scaling
SMC_MTF_LINE_EXT   = 20    // Multiplier for extending MTF level lines forward

// ============================================================================
//                      SHARED UTILITY FUNCTIONS
// ============================================================================

f_getLabelSize(string sz) =>
    switch sz
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        => size.small

f_getLineStyle(string style) =>
    switch style
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted

// ============================================================================
//                     MODULE: MARKET STRUCTURE
// ============================================================================

// --- Settings ---

ms_zigzag_len = input.int(10, "Zigzag Length", minval=1, maxval=50, group="Market Structure", tooltip="Number of bars to look back for detecting swing pivots")
ms_source     = input.string("Wick", "Source", options=["Wick", "Body"], group="Market Structure", tooltip="Use candle wicks or bodies for pivot detection")
ms_lineColor  = input.color(#000000, "Line Color", inline="ms_col", group="Market Structure")
ms_lineWidth  = input.int(2, "Line Width", minval=1, maxval=5, inline="ms_line", group="Market Structure", tooltip="Thickness of the zigzag lines")
ms_labelSize  = input.string("Small", "Label Size", options=["Tiny", "Small", "Normal", "Large"], inline="ms_line", group="Market Structure", tooltip="Size of HH/HL/LH/LL labels")

// --- Constants ---

MS_SIZE = f_getLabelSize(ms_labelSize)

// --- Variables ---

var float[] ms_high_points_arr = array.new_float(5)
var int[]   ms_high_index_arr  = array.new_int(5)
var float[] ms_low_points_arr  = array.new_float(5)
var int[]   ms_low_index_arr   = array.new_int(5)

var float  ms_hiPivot  = na
var float  ms_loPivot  = na
var int    ms_hiBar    = na
var int    ms_loBar    = na
var float  ms_hiRef    = na
var float  ms_loRef    = na
var line   ms_liveLn   = na
var label  ms_liveLb   = na

// --- Functions ---

f_ms_get_high(ind) =>
    [array.get(ms_high_points_arr, array.size(ms_high_points_arr) - 1 - ind), array.get(ms_high_index_arr, array.size(ms_high_index_arr) - 1 - ind)]

f_ms_get_low(ind) =>
    [array.get(ms_low_points_arr, array.size(ms_low_points_arr) - 1 - ind), array.get(ms_low_index_arr, array.size(ms_low_index_arr) - 1 - ind)]

f_getHiLabel(price) =>
    result = ""
    if na(ms_hiPivot)
        result := "High"
    else if price <= ms_hiPivot
        result := "LH"
    else
        if na(ms_hiRef)
            result := "High"
        else if price > ms_hiRef
            result := "HH"
        else
            result := "High"
    result

f_getLoLabel(price) =>
    result = ""
    if na(ms_loPivot)
        result := "Low"
    else if price >= ms_loPivot
        result := "HL"
    else
        if na(ms_loRef)
            result := "Low"
        else if price < ms_loRef
            result := "LL"
        else
            result := "Low"
    result

// --- Execution ---

ms_hi = ms_source == "Wick" ? high : math.max(open, close)
ms_lo = ms_source == "Wick" ? low  : math.min(open, close)
ms_to_up   = ms_hi >= ta.highest(ms_hi, ms_zigzag_len)
ms_to_down = ms_lo <= ta.lowest(ms_lo, ms_zigzag_len)

ms_trend = 1
ms_trend := nz(ms_trend[1], 1)
ms_trend := ms_trend == 1 and ms_to_down ? -1 : ms_trend == -1 and ms_to_up ? 1 : ms_trend

ms_last_trend_up_since   = ta.barssince(ms_to_up[1])
ms_low_val  = ta.lowest(ms_lo, nz(ms_last_trend_up_since > 0 ? ms_last_trend_up_since : 1, 1))
ms_low_idx  = bar_index - ta.barssince(ms_low_val == ms_lo)

ms_last_trend_down_since = ta.barssince(ms_to_down[1])
ms_high_val = ta.highest(ms_hi, nz(ms_last_trend_down_since > 0 ? ms_last_trend_down_since : 1, 1))
ms_high_idx = bar_index - ta.barssince(ms_high_val == ms_hi)

if ta.change(ms_trend) != 0 and show_market_structure
    if ms_trend == 1
        array.push(ms_low_points_arr, ms_low_val)
        array.push(ms_low_index_arr, ms_low_idx)
    if ms_trend == -1
        array.push(ms_high_points_arr, ms_high_val)
        array.push(ms_high_index_arr, ms_high_idx)

[ms_h0, ms_h0i] = f_ms_get_high(0)
[ms_l0, ms_l0i] = f_ms_get_low(0)

if ta.change(ms_trend) != 0 and show_market_structure
    if ms_trend == -1
        // High pivot confirmed
        lbl = f_getHiLabel(ms_h0)

        if lbl == "High"
            ms_hiRef := ms_h0
            ms_loRef := na
        else if lbl == "HH"
            ms_hiRef := ms_h0

        if not na(ms_loBar)
            line.new(ms_loBar, ms_loPivot, ms_h0i, ms_h0, color=ms_lineColor, width=ms_lineWidth)
            label.new(ms_h0i, ms_h0, lbl, style=label.style_label_down, color=COLOR_TRANSPARENT, textcolor=color.black, size=MS_SIZE)

        ms_hiPivot := ms_h0
        ms_hiBar   := ms_h0i

    if ms_trend == 1
        // Low pivot confirmed
        lbl = f_getLoLabel(ms_l0)

        if lbl == "Low"
            ms_loRef := ms_l0
            ms_hiRef := na
        else if lbl == "LL"
            ms_loRef := ms_l0

        if not na(ms_hiBar)
            line.new(ms_hiBar, ms_hiPivot, ms_l0i, ms_l0, color=ms_lineColor, width=ms_lineWidth)
            label.new(ms_l0i, ms_l0, lbl, style=label.style_label_up, color=COLOR_TRANSPARENT, textcolor=color.black, size=MS_SIZE)

        ms_loPivot := ms_l0
        ms_loBar   := ms_l0i

// Live leg for market structure
if barstate.islast and show_market_structure
    if not na(ms_liveLn)
        line.delete(ms_liveLn)
    if not na(ms_liveLb)
        label.delete(ms_liveLb)

    if ms_trend == -1 and not na(ms_hiBar)
        // Trending down - show potential low
        ms_liveLn := line.new(ms_hiBar, ms_hiPivot, ms_low_idx, ms_low_val, color=ms_lineColor, width=ms_lineWidth)
        lbl = f_getLoLabel(ms_low_val)
        ms_liveLb := label.new(ms_low_idx, ms_low_val, lbl, style=label.style_label_up, color=COLOR_TRANSPARENT, textcolor=color.black, size=MS_SIZE)

    else if ms_trend == 1 and not na(ms_loBar)
        // Trending up - show potential high
        ms_liveLn := line.new(ms_loBar, ms_loPivot, ms_high_idx, ms_high_val, color=ms_lineColor, width=ms_lineWidth)
        lbl = f_getHiLabel(ms_high_val)
        ms_liveLb := label.new(ms_high_idx, ms_high_val, lbl, style=label.style_label_down, color=COLOR_TRANSPARENT, textcolor=color.black, size=MS_SIZE)

// ============================================================================
//                        MODULE: TRIPLE EMA
// ============================================================================

// --- Settings ---

ema_len1 = input.int(50, "EMA 1 Length", minval=1, group="Triple EMA", tooltip="Period for the fast EMA")
ema_col1 = input.color(#f7525f, "EMA 1 Color", inline="ema1", group="Triple EMA")
ema_len2 = input.int(100, "EMA 2 Length", minval=1, group="Triple EMA", tooltip="Period for the medium EMA")
ema_col2 = input.color(#22ab94, "EMA 2 Color", inline="ema2", group="Triple EMA")
ema_len3 = input.int(200, "EMA 3 Length", minval=1, group="Triple EMA", tooltip="Period for the slow EMA")
ema_col3 = input.color(color.rgb(0, 0, 0), "EMA 3 Color", inline="ema3", group="Triple EMA")

// --- Execution ---

ema1 = ta.ema(close, ema_len1)
ema2 = ta.ema(close, ema_len2)
ema3 = ta.ema(close, ema_len3)

plot(show_ema ? ema1 : na, title="EMA 1", color=ema_col1, linewidth=1, display=display.all - display.status_line)
plot(show_ema ? ema2 : na, title="EMA 2", color=ema_col2, linewidth=1, display=display.all - display.status_line)
plot(show_ema ? ema3 : na, title="EMA 3", color=ema_col3, linewidth=1, display=display.all - display.status_line)

// ============================================================================
//                        MODULE: SESSIONS
// ============================================================================

// --- Settings ---

// New York
ses_show_ny   = input.bool(true, "New York", inline="ses_ny", group="Sessions", tooltip="Show New York session (default 1300-2200 UTC)")
ses_ny_time   = input.session("1300-2200", "", inline="ses_ny", group="Sessions")
ses_ny_color  = input.color(#ff5d00, "", inline="ses_ny", group="Sessions")

// London
ses_show_ldn  = input.bool(true, "London", inline="ses_ldn", group="Sessions", tooltip="Show London session (default 0700-1600 UTC)")
ses_ldn_time  = input.session("0700-1600", "", inline="ses_ldn", group="Sessions")
ses_ldn_color = input.color(#2157f3, "", inline="ses_ldn", group="Sessions")

// Asia
ses_show_asia  = input.bool(true, "Asia", inline="ses_asia", group="Sessions", tooltip="Show Asia session (default 0000-0900 UTC)")
ses_asia_time  = input.session("0000-0900", "", inline="ses_asia", group="Sessions")
ses_asia_color = input.color(#e91e63, "", inline="ses_asia", group="Sessions")

// Dividers always shown
ses_show_divider = true
ses_show_hl      = input.bool(false, "Session High/Low Lines", group="Sessions", tooltip="Draw horizontal lines at session high and low levels")

ses_line_ext     = input.int(30, "Line Extension", minval=5, maxval=100, group="Sessions", tooltip="Number of bars to extend session high/low lines forward")

// --- Functions ---

ses_draw_hl(bool is_active, bool show, color css, string tag) =>
    var float ses_h = na
    var float ses_l = na
    var line  ses_h_line = na
    var line  ses_l_line = na
    var label ses_h_lbl = na
    var label ses_l_lbl = na
    if show
        if is_active and not is_active[1]
            ses_h := high
            ses_l := low
            line.delete(ses_h_line)
            line.delete(ses_l_line)
            label.delete(ses_h_lbl)
            label.delete(ses_l_lbl)
            ses_h_line := line.new(bar_index, ses_h, bar_index + ses_line_ext, ses_h, color=css, style=line.style_dashed)
            ses_l_line := line.new(bar_index, ses_l, bar_index + ses_line_ext, ses_l, color=css, style=line.style_dashed)
            ses_h_lbl := label.new(bar_index + ses_line_ext, ses_h, tag + "H", style=label.style_label_left, color=COLOR_TRANSPARENT, textcolor=css, size=size.tiny)
            ses_l_lbl := label.new(bar_index + ses_line_ext, ses_l, tag + "L", style=label.style_label_left, color=COLOR_TRANSPARENT, textcolor=css, size=size.tiny)
        if is_active
            if high > ses_h
                ses_h := high
            if low < ses_l
                ses_l := low
            line.set_y1(ses_h_line, ses_h), line.set_y2(ses_h_line, ses_h)
            line.set_y1(ses_l_line, ses_l), line.set_y2(ses_l_line, ses_l)
        line.set_x2(ses_h_line, bar_index + ses_line_ext)
        line.set_x2(ses_l_line, bar_index + ses_line_ext)
        label.set_x(ses_h_lbl, bar_index + ses_line_ext), label.set_y(ses_h_lbl, ses_h)
        label.set_x(ses_l_lbl, bar_index + ses_line_ext), label.set_y(ses_l_lbl, ses_l)
    [ses_h, ses_l, ses_h_line, ses_l_line, ses_h_lbl, ses_l_lbl]

ses_is_close(float a, float b, float thr) =>
    not na(a) and not na(b) and math.abs(a - b) < thr

// --- Execution ---

ses_tf = timeframe.period

var ses_tz = syminfo.timezone

ses_is_ny   = nz(time(ses_tf, ses_ny_time, ses_tz)) > 0
ses_is_ldn  = nz(time(ses_tf, ses_ldn_time, ses_tz)) > 0
ses_is_asia = nz(time(ses_tf, ses_asia_time, ses_tz)) > 0

// Only show dividers on intraday timeframes <= 30min
ses_show_divider_tf = timeframe.isintraday and timeframe.multiplier <= 30

// New York session dividers
plotshape(show_sessions and ses_is_ny and ses_show_divider and ses_show_ny and ses_show_divider_tf, "NY"
  , shape.square
  , location.bottom
  , na
  , text = "."
  , textcolor = ses_ny_color
  , size = size.tiny
  , display = display.all - display.status_line
  , editable = false)

plotshape(show_sessions and ses_is_ny != ses_is_ny[1] and ses_show_divider and ses_show_ny and ses_show_divider_tf, "NYE"
  , shape.labelup
  , location.bottom
  , na
  , text = "I"
  , textcolor = ses_ny_color
  , size = size.tiny
  , display = display.all - display.status_line
  , editable = false)

// London session dividers
plotshape(show_sessions and ses_is_ldn and ses_show_divider and ses_show_ldn and ses_show_divider_tf, "LDN"
  , shape.labelup
  , location.bottom
  , na
  , text = "."
  , textcolor = ses_ldn_color
  , size = size.tiny
  , display = display.all - display.status_line
  , editable = false)

plotshape(show_sessions and ses_is_ldn != ses_is_ldn[1] and ses_show_divider and ses_show_ldn and ses_show_divider_tf, "LDNE"
  , shape.labelup
  , location.bottom
  , na
  , text = "I"
  , textcolor = ses_ldn_color
  , size = size.tiny
  , display = display.all - display.status_line
  , editable = false)

// Asia session dividers
plotshape(show_sessions and ses_is_asia and ses_show_divider and ses_show_asia and ses_show_divider_tf, "ASIA"
  , shape.square
  , location.bottom
  , na
  , text = "."
  , textcolor = ses_asia_color
  , size = size.tiny
  , display = display.all - display.status_line
  , editable = false)

plotshape(show_sessions and ses_is_asia != ses_is_asia[1] and ses_show_divider and ses_show_asia and ses_show_divider_tf, "ASIAE"
  , shape.labelup
  , location.bottom
  , na
  , text = "I"
  , textcolor = ses_asia_color
  , size = size.tiny
  , display = display.all - display.status_line
  , editable = false)

// Session High/Low Lines (intraday only - daily bars span all 24h so session detection is meaningless)
if show_sessions and ses_show_hl and timeframe.isintraday
    [ny_h, ny_l, ny_hl, ny_ll, ny_hlbl, ny_llbl] = ses_draw_hl(ses_is_ny, ses_show_ny, ses_ny_color, "NY")
    [ld_h, ld_l, ld_hl, ld_ll, ld_hlbl, ld_llbl] = ses_draw_hl(ses_is_ldn, ses_show_ldn, ses_ldn_color, "LD")
    [as_h, as_l, as_hl, as_ll, as_hlbl, as_llbl] = ses_draw_hl(ses_is_asia, ses_show_asia, ses_asia_color, "AS")

    ses_thr = ta.atr(SES_ATR_PERIOD) * SES_OVERLAP_MULT

    // LD overlaps NY → extend LD to +38
    if ses_is_close(ld_h, ny_h, ses_thr) or ses_is_close(ld_h, ny_l, ses_thr)
        line.set_x2(ld_hl, bar_index + ses_line_ext + 8), label.set_x(ld_hlbl, bar_index + ses_line_ext + 8)
    if ses_is_close(ld_l, ny_h, ses_thr) or ses_is_close(ld_l, ny_l, ses_thr)
        line.set_x2(ld_ll, bar_index + ses_line_ext + 8), label.set_x(ld_llbl, bar_index + ses_line_ext + 8)

    // AS overlaps NY or LD → extend AS to +38, or +46 if both
    as_h_vs_ny = ses_is_close(as_h, ny_h, ses_thr) or ses_is_close(as_h, ny_l, ses_thr)
    as_h_vs_ld = ses_is_close(as_h, ld_h, ses_thr) or ses_is_close(as_h, ld_l, ses_thr)
    if as_h_vs_ny and as_h_vs_ld
        line.set_x2(as_hl, bar_index + ses_line_ext + 16), label.set_x(as_hlbl, bar_index + ses_line_ext + 16)
    else if as_h_vs_ny or as_h_vs_ld
        line.set_x2(as_hl, bar_index + ses_line_ext + 8), label.set_x(as_hlbl, bar_index + ses_line_ext + 8)

    as_l_vs_ny = ses_is_close(as_l, ny_h, ses_thr) or ses_is_close(as_l, ny_l, ses_thr)
    as_l_vs_ld = ses_is_close(as_l, ld_h, ses_thr) or ses_is_close(as_l, ld_l, ses_thr)
    if as_l_vs_ny and as_l_vs_ld
        line.set_x2(as_ll, bar_index + ses_line_ext + 16), label.set_x(as_llbl, bar_index + ses_line_ext + 16)
    else if as_l_vs_ny or as_l_vs_ld
        line.set_x2(as_ll, bar_index + ses_line_ext + 8), label.set_x(as_llbl, bar_index + ses_line_ext + 8)

// ============================================================================
//                          MODULE: SMC
// ============================================================================

// --- Settings: Strong/Weak HL ---

smc_show_hl        = input.bool(true, "Strong/Weak High/Low", group="Smart Money Concepts", tooltip="Label the current swing high and low as strong or weak based on trend direction")
smc_hl_bull_color  = input.color(#000000, "Bullish Color", inline="hl_col", group="Smart Money Concepts")
smc_hl_bear_color  = input.color(#000000, "Bearish Color", inline="hl_col", group="Smart Money Concepts")

// --- Settings: Equal HL ---

smc_show_eqhl      = input.bool(true, "Equal Highs/Lows", group="Smart Money Concepts", tooltip="Detect when consecutive swing highs or lows form at similar price levels")
smc_eqhl_len       = input.int(3, "Equal HL Confirmation Bars", minval=1, group="Smart Money Concepts", tooltip="Number of bars to confirm an equal high or low")
smc_eqhl_threshold = input.float(0.1, "Equal HL Threshold", minval=0, maxval=0.5, step=0.1, group="Smart Money Concepts", tooltip="ATR fraction - swings closer than this are considered equal")

// --- Settings: MTF Levels ---

smc_show_daily     = input.bool(true, "Daily Levels", inline="daily", group="Smart Money Concepts", tooltip="Show previous daily high and low levels")
smc_daily_style    = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="daily", group="Smart Money Concepts")
smc_daily_color    = input.color(#000000, "", inline="daily", group="Smart Money Concepts")
smc_show_weekly    = input.bool(false, "Weekly Levels", inline="weekly", group="Smart Money Concepts", tooltip="Show previous weekly high and low levels")
smc_weekly_style   = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="weekly", group="Smart Money Concepts")
smc_weekly_color   = input.color(#000000, "", inline="weekly", group="Smart Money Concepts")
smc_show_monthly   = input.bool(false, "Monthly Levels", inline="monthly", group="Smart Money Concepts", tooltip="Show previous monthly high and low levels")
smc_monthly_style  = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="monthly", group="Smart Money Concepts")
smc_monthly_color  = input.color(#000000, "", inline="monthly", group="Smart Money Concepts")

// --- Settings: Zones ---

smc_show_zones     = input.bool(true, "", inline="pd_toggle", group="Smart Money Concepts")
smc_zone_lookback  = input.int(10, "Premium & Discount Length", minval=5, step=5, inline="pd_toggle", group="Smart Money Concepts", tooltip="Number of bars for zone lookback and forward extension")

// --- Constants ---

// Auto-adjusts based on timeframe to capture meaningful swing structure
// Lower TFs: more bars needed to filter noise
// Higher TFs: fewer bars needed (each bar is more significant)
smc_swing_len = switch
    timeframe.isseconds => 50                                    // Seconds (rare)
    timeframe.isminutes and timeframe.multiplier <= 5 => 20      // 1-5m: ~1.5 hours
    timeframe.isminutes and timeframe.multiplier <= 15 => 25     // 6-15m: ~6 hours
    timeframe.isminutes and timeframe.multiplier <= 30 => 30     // 16-30m: ~15 hours
    timeframe.isminutes and timeframe.multiplier <= 60 => 35     // 31-60m: ~1.5 days
    timeframe.isminutes and timeframe.multiplier <= 240 => 40    // 2-4H: ~7 days
    timeframe.isdaily => 20                                      // Daily: ~1 month
    timeframe.isweekly => 12                                     // Weekly: ~3 months
    timeframe.ismonthly => 6                                     // Monthly: ~6 months
    => 30                                                        // Default

// --- Types ---

type smc_trailing
    float top
    float bottom
    int barTime
    int barIndex
    int lastTopTime
    int lastBottomTime

type smc_trend
    int bias

type smc_eqDisplay
    line l_ine = na
    label l_abel = na

type smc_pivot
    float currentLevel
    float lastLevel
    bool crossed
    int barTime = na
    int barIndex = na

// --- Variables ---

var smc_pivot smc_swingHigh     = smc_pivot.new(na, na, false)
var smc_pivot smc_swingLow      = smc_pivot.new(na, na, false)
var smc_pivot smc_equalHigh     = smc_pivot.new(na, na, false)
var smc_pivot smc_equalLow      = smc_pivot.new(na, na, false)
var smc_trend smc_swingTrend    = smc_trend.new(0)
var smc_trailing smc_trail      = smc_trailing.new()
var smc_eqDisplay smc_eqhDisp   = smc_eqDisplay.new()
var smc_eqDisplay smc_eqlDisp   = smc_eqDisplay.new()
var array<float> smc_highs      = array.new<float>()
var array<float> smc_lows       = array.new<float>()
var array<int> smc_times        = array.new<int>()
var smc_initialTime             = time

// --- Premium/Discount Zone Variables ---
var float pd_eq_val  = na
var float pd_hi_val  = na
var float pd_lo_val  = na
var array<float> pd_highs  = array.new_float(0)
var array<float> pd_lows   = array.new_float(0)
var array<float> pd_posVol = array.new_float(0)
var array<float> pd_negVol = array.new_float(0)
var float pd_deltaVol      = na
var box pd_midBox            = na
var line pd_eqLine           = na
var label pd_eqLabel         = na

smc_atrMeasure = ta.atr(SMC_ATR_PERIOD)

// Store price data (capped at SMC_MAX_ARRAY_SIZE to prevent unbounded memory growth)
smc_highs.push(high)
smc_lows.push(low)
smc_times.push(time)

if smc_highs.size() > SMC_MAX_ARRAY_SIZE
    smc_highs.shift()
    smc_lows.shift()
    smc_times.shift()

// --- Functions ---

// Leg detection for swing structure
smc_leg(int size) =>
    var leg = 0
    newLegHigh = high[size] > ta.highest(size)
    newLegLow  = low[size] < ta.lowest(size)
    if newLegHigh
        leg := 0
    else if newLegLow
        leg := 1
    leg

smc_startOfNewLeg(int leg)     => ta.change(leg) != 0
smc_startOfBullishLeg(int leg) => ta.change(leg) == 1
smc_startOfBearishLeg(int leg) => ta.change(leg) == -1

// Draw Equal High/Low
smc_drawEqualHL(smc_pivot p, float level, int size, bool isHigh) =>
    smc_eqDisplay disp = isHigh ? smc_eqhDisp : smc_eqlDisp
    string tag = isHigh ? "EQH" : "EQL"
    color eqColor = isHigh ? smc_hl_bear_color : smc_hl_bull_color
    string lblStyle = isHigh ? label.style_label_down : label.style_label_up

    line.delete(disp.l_ine)
    label.delete(disp.l_abel)

    disp.l_ine := line.new(chart.point.new(p.barTime, na, p.currentLevel), chart.point.new(time[size], na, level), xloc=xloc.bar_time, color=eqColor, style=line.style_dotted)
    labelPos = math.round(0.5 * (p.barIndex + bar_index - size))
    disp.l_abel := label.new(chart.point.new(na, labelPos, level), tag, xloc.bar_index, color=COLOR_TRANSPARENT, textcolor=eqColor, style=lblStyle, size=size.tiny)

// Get current structure for EQH/EQL and swing tracking
smc_getCurrentStructure(int size, bool forEqHL) =>
    currentLeg = smc_leg(size)
    newPivot = smc_startOfNewLeg(currentLeg)
    pivotLow = smc_startOfBullishLeg(currentLeg)
    pivotHigh = smc_startOfBearishLeg(currentLeg)

    if newPivot
        if pivotLow
            smc_pivot p = forEqHL ? smc_equalLow : smc_swingLow

            if forEqHL and show_smc and smc_show_eqhl and math.abs(p.currentLevel - low[size]) < smc_eqhl_threshold * smc_atrMeasure
                smc_drawEqualHL(p, low[size], size, false)

            p.lastLevel := p.currentLevel
            p.currentLevel := low[size]
            p.crossed := false
            p.barTime := time[size]
            p.barIndex := bar_index[size]

            if not forEqHL
                smc_trail.bottom := p.currentLevel
                smc_trail.barTime := p.barTime
                smc_trail.barIndex := p.barIndex
                smc_trail.lastBottomTime := p.barTime
        else
            smc_pivot p = forEqHL ? smc_equalHigh : smc_swingHigh

            if forEqHL and show_smc and smc_show_eqhl and math.abs(p.currentLevel - high[size]) < smc_eqhl_threshold * smc_atrMeasure
                smc_drawEqualHL(p, high[size], size, true)

            p.lastLevel := p.currentLevel
            p.currentLevel := high[size]
            p.crossed := false
            p.barTime := time[size]
            p.barIndex := bar_index[size]

            if not forEqHL
                smc_trail.top := p.currentLevel
                smc_trail.barTime := p.barTime
                smc_trail.barIndex := p.barIndex
                smc_trail.lastTopTime := p.barTime

// Detect swing structure for trend (no display)
smc_detectSwingTrend() =>
    if ta.crossover(close, smc_swingHigh.currentLevel) and not smc_swingHigh.crossed
        smc_swingHigh.crossed := true
        smc_swingTrend.bias := BULLISH

    if ta.crossunder(close, smc_swingLow.currentLevel) and not smc_swingLow.crossed
        smc_swingLow.crossed := true
        smc_swingTrend.bias := BEARISH

// Update trailing extremes
smc_updateTrailing() =>
    smc_trail.top := math.max(high, smc_trail.top)
    smc_trail.lastTopTime := smc_trail.top == high ? time : smc_trail.lastTopTime
    smc_trail.bottom := math.min(low, smc_trail.bottom)
    smc_trail.lastBottomTime := smc_trail.bottom == low ? time : smc_trail.lastBottomTime

// Draw Strong/Weak High Low
smc_drawHighLowSwings() =>
    var line topLine = line.new(na, na, na, na, color=smc_hl_bear_color, xloc=xloc.bar_time)
    var line bottomLine = line.new(na, na, na, na, color=smc_hl_bull_color, xloc=xloc.bar_time)
    var label topLabel = label.new(na, na, color=COLOR_TRANSPARENT, textcolor=smc_hl_bear_color, xloc=xloc.bar_time, style=label.style_label_down, size=size.tiny)
    var label bottomLabel = label.new(na, na, color=COLOR_TRANSPARENT, textcolor=smc_hl_bull_color, xloc=xloc.bar_time, style=label.style_label_up, size=size.tiny)

    rightTimeBar = last_bar_time + SMC_MTF_LINE_EXT * (time - time[1])

    topLine.set_first_point(chart.point.new(smc_trail.lastTopTime, na, smc_trail.top))
    topLine.set_second_point(chart.point.new(rightTimeBar, na, smc_trail.top))
    topLabel.set_point(chart.point.new(rightTimeBar, na, smc_trail.top))
    topLabel.set_text(smc_swingTrend.bias == BEARISH ? "Strong High" : "Weak High")

    bottomLine.set_first_point(chart.point.new(smc_trail.lastBottomTime, na, smc_trail.bottom))
    bottomLine.set_second_point(chart.point.new(rightTimeBar, na, smc_trail.bottom))
    bottomLabel.set_point(chart.point.new(rightTimeBar, na, smc_trail.bottom))
    bottomLabel.set_text(smc_swingTrend.bias == BULLISH ? "Strong Low" : "Weak Low")

// Check if higher timeframe
smc_higherTF(string tf) => timeframe.in_seconds() > timeframe.in_seconds(tf)

// Draw MTF levels
smc_drawLevels(string tf, bool sameTF, string style, color levelColor) =>
    [topLevel, bottomLevel, leftTime, rightTime] = request.security(syminfo.tickerid, tf, [high[1], low[1], time[1], time], lookahead=barmerge.lookahead_on)

    float parsedTop = sameTF ? high : topLevel
    float parsedBottom = sameTF ? low : bottomLevel
    int parsedLeftTime = sameTF ? time : leftTime
    int parsedRightTime = sameTF ? time : rightTime
    int parsedTopTime = time
    int parsedBottomTime = time

    if not sameTF
        int leftIndex = smc_times.binary_search_rightmost(parsedLeftTime)
        int rightIndex = smc_times.binary_search_rightmost(parsedRightTime)

        if leftIndex < rightIndex
            array<int> timeArray = smc_times.slice(leftIndex, rightIndex)
            array<float> topArray = smc_highs.slice(leftIndex, rightIndex)
            array<float> bottomArray = smc_lows.slice(leftIndex, rightIndex)

            parsedTopTime := timeArray.size() > 0 ? timeArray.get(topArray.indexof(topArray.max())) : smc_initialTime
            parsedBottomTime := timeArray.size() > 0 ? timeArray.get(bottomArray.indexof(bottomArray.min())) : smc_initialTime

    var line topLine = line.new(na, na, na, na, xloc=xloc.bar_time, color=levelColor, style=f_getLineStyle(style))
    var line bottomLine = line.new(na, na, na, na, xloc=xloc.bar_time, color=levelColor, style=f_getLineStyle(style))
    var label topLabel = label.new(na, na, xloc=xloc.bar_time, text=str.format("P{0}H", tf), color=COLOR_TRANSPARENT, textcolor=levelColor, size=size.small, style=label.style_label_left)
    var label bottomLabel = label.new(na, na, xloc=xloc.bar_time, text=str.format("P{0}L", tf), color=COLOR_TRANSPARENT, textcolor=levelColor, size=size.small, style=label.style_label_left)

    rightEdge = last_bar_time + SMC_MTF_LINE_EXT * (time - time[1])

    topLine.set_first_point(chart.point.new(parsedTopTime, na, parsedTop))
    topLine.set_second_point(chart.point.new(rightEdge, na, parsedTop))
    topLabel.set_point(chart.point.new(rightEdge, na, parsedTop))

    bottomLine.set_first_point(chart.point.new(parsedBottomTime, na, parsedBottom))
    bottomLine.set_second_point(chart.point.new(rightEdge, na, parsedBottom))
    bottomLabel.set_point(chart.point.new(rightEdge, na, parsedBottom))

// --- Execution ---

// Update trailing and structure
if show_smc and smc_show_hl
    smc_updateTrailing()

// Get swing structure (needed for Strong/Weak detection)
smc_getCurrentStructure(smc_swing_len, false)

// Detect swing trend
smc_detectSwingTrend()

// Draw Strong/Weak labels (only when SMC enabled)
if show_smc and smc_show_hl
    smc_drawHighLowSwings()

// Get EQH/EQL structure
if show_smc and smc_show_eqhl
    smc_getCurrentStructure(smc_eqhl_len, true)

// MTF Levels - draw on last confirmed bar or realtime
varip int smc_currentBarIndex = bar_index
varip int smc_lastBarIndex = bar_index
smc_lastBarIndex := smc_currentBarIndex
smc_currentBarIndex := bar_index
smc_newBar = smc_currentBarIndex != smc_lastBarIndex

if barstate.islastconfirmedhistory or (barstate.isrealtime and smc_newBar)
    if show_smc and smc_show_daily and not smc_higherTF("D")
        smc_drawLevels("D", timeframe.isdaily, smc_daily_style, smc_daily_color)

    if show_smc and smc_show_weekly and not smc_higherTF("W")
        smc_drawLevels("W", timeframe.isweekly, smc_weekly_style, smc_weekly_color)

    if show_smc and smc_show_monthly and not smc_higherTF("M")
        smc_drawLevels("M", timeframe.ismonthly, smc_monthly_style, smc_monthly_color)

// Premium/Discount Zones (lookback-based with delta volume, minimum 1H)
// Use 1H data when chart is below 1H, otherwise use chart's own timeframe
pd_tf = timeframe.in_seconds() < timeframe.in_seconds("60") ? "60" : timeframe.period

// Fetch OHLCV from the effective timeframe (runs every bar, not just barstate.islast)
pd_htf_high   = request.security(syminfo.tickerid, pd_tf, high)
pd_htf_low    = request.security(syminfo.tickerid, pd_tf, low)
pd_htf_open   = request.security(syminfo.tickerid, pd_tf, open)
pd_htf_close  = request.security(syminfo.tickerid, pd_tf, close)
pd_htf_volume = request.security(syminfo.tickerid, pd_tf, volume)
pd_htf_atr    = request.security(syminfo.tickerid, pd_tf, ta.atr(200)) * 0.8

if show_smc and smc_show_zones and barstate.islast
    pd_startIdx = bar_index - smc_zone_lookback
    pd_endIdx   = bar_index + 50

    // Collect data over lookback period using HTF values
    array.clear(pd_highs)
    array.clear(pd_lows)

    // Resize volume arrays
    while pd_posVol.size() < smc_zone_lookback
        pd_posVol.push(0.)
    while pd_negVol.size() < smc_zone_lookback
        pd_negVol.push(0.)
    while pd_posVol.size() > smc_zone_lookback
        pd_posVol.pop()
    while pd_negVol.size() > smc_zone_lookback
        pd_negVol.pop()

    for i = 0 to smc_zone_lookback - 1
        array.push(pd_highs, pd_htf_high[i])
        array.push(pd_lows, pd_htf_low[i])
        if pd_htf_close[i] > pd_htf_open[i]
            pd_posVol.set(i, pd_htf_volume[i])
            pd_negVol.set(i, 0.)
        else if pd_htf_close[i] < pd_htf_open[i]
            pd_negVol.set(i, -pd_htf_volume[i])
            pd_posVol.set(i, 0.)
        else
            pd_posVol.set(i, 0.)
            pd_negVol.set(i, 0.)

    pd_hiMax = pd_highs.max()
    pd_loMin = pd_lows.min()

    pd_eq_val := math.avg(pd_loMin, pd_hiMax)
    pd_hi_val := pd_hiMax
    pd_lo_val := pd_loMin

    // Delete previous boxes and line
    box.delete(pd_midBox[1])
    line.delete(pd_eqLine[1])
    label.delete(pd_eqLabel[1])

    // Mid-zone background fill (between premium and discount)
    pd_deltaVol := pd_posVol.avg() != 0 ? (pd_negVol.avg() / pd_posVol.avg() + 1) * 100 : 0
    pd_deltaVol := math.min(math.max(pd_deltaVol, -100), 100)
    pd_midBox := box.new(pd_startIdx, pd_hiMax, pd_endIdx, pd_loMin, na, 0, bgcolor=color.new(pd_deltaVol > 0 ? COLOR_DISCOUNT : COLOR_PREMIUM, 93))

    // Equilibrium line (true 0.5)
    pd_eqLevel = math.avg(pd_loMin, pd_hiMax)
    pd_eqLine := line.new(pd_startIdx, pd_eqLevel, pd_endIdx, pd_eqLevel, color=chart.fg_color, style=line.style_dashed)
    pd_eqLabel := label.new(pd_endIdx, pd_eqLevel, "Equilibrium", style=label.style_label_left, color=COLOR_TRANSPARENT, textcolor=chart.fg_color, size=size.small)

// ============================================================================
//                    MODULE: ChoCH / BOS (Market Structure)
// ============================================================================
// Swing detection via ta.pivothigh / ta.pivotlow (Pine v6 compatible)

// --- Settings ---

cb_length  = input.int(1, "Pivot Length", minval=1, group='ChoCH / BOS', tooltip="Lookback bars for detecting swing pivots used in CHoCH/BOS detection")
cb_bullCss = input.color(color.new(#22ab94, 0), "Bullish", group='ChoCH / BOS', inline='cb_bull')
cb_bearCss = input.color(color.new(#f7525f, 0), "Bearish", group='ChoCH / BOS', inline='cb_bear')

// --- Swing Detection ---

cb_ph = ta.pivothigh(high, cb_length, cb_length)
cb_pl = ta.pivotlow(low, cb_length, cb_length)

var float cb_upper_val = na
var int   cb_upper_loc = na
var bool  cb_upper_crossed = false

var float cb_lower_val = na
var int   cb_lower_loc = na
var bool  cb_lower_crossed = false

var int cb_os = 0

if not na(cb_ph)
    cb_upper_val := high[cb_length]
    cb_upper_loc := bar_index - cb_length
    cb_upper_crossed := false

if not na(cb_pl)
    cb_lower_val := low[cb_length]
    cb_lower_loc := bar_index - cb_length
    cb_lower_crossed := false

// --- Bullish ChoCH/BOS: close crosses above swing high ---

if ta.crossover(close, cb_upper_val) and not cb_upper_crossed
    if show_choch_bos
        line.new(cb_upper_loc, cb_upper_val, bar_index, cb_upper_val, color = cb_bullCss)
        label.new(int(math.avg(bar_index, cb_upper_loc)), cb_upper_val, cb_os == -1 ? 'ChoCH' : 'BOS'
          , color = COLOR_TRANSPARENT
          , textcolor = cb_bullCss
          , style = label.style_label_down
          , size = size.tiny)

    cb_upper_crossed := true
    cb_os := 1

// --- Bearish ChoCH/BOS: close crosses below swing low ---

if ta.crossunder(close, cb_lower_val) and not cb_lower_crossed
    if show_choch_bos
        line.new(cb_lower_loc, cb_lower_val, bar_index, cb_lower_val, color = cb_bearCss)
        label.new(int(math.avg(bar_index, cb_lower_loc)), cb_lower_val, cb_os == 1 ? 'ChoCH' : 'BOS'
          , color = COLOR_TRANSPARENT
          , textcolor = cb_bearCss
          , style = label.style_label_up
          , size = size.tiny)

    cb_lower_crossed := true
    cb_os := -1

bool alert_choch_bull = cb_os == 1 and cb_os[1] != 1
bool alert_choch_bear = cb_os == -1 and cb_os[1] != -1

// ============================================================================
//                      MODULE: FAIR VALUE GAPS
// ============================================================================

// --- Settings ---

fvg_threshold_pct = input.float(0, "Threshold %", minval=0, maxval=100, step=0.1, inline="fvg_thr", group="Fair Value Gaps", tooltip="Minimum gap size as percentage of price. 0 = show all FVGs")
fvg_auto_threshold = input(false, "Auto", inline="fvg_thr", group="Fair Value Gaps", tooltip="Automatically calculate threshold based on average bar range")
fvg_show_last = input.int(0, "Unmitigated Levels", minval=0, group="Fair Value Gaps", tooltip="Show lines at unmitigated FVG levels. 0 = disabled")
fvg_mitigation_levels = input.bool(false, "Mitigation Levels", group="Fair Value Gaps", tooltip="Show dashed lines where FVGs were mitigated")
fvg_tf = input.timeframe("", "Timeframe", group="Fair Value Gaps", tooltip="Timeframe for FVG detection. Empty = chart timeframe")

// --- Constants ---
FVG_EXTEND = 20  // Bars to extend FVG boxes forward

// --- Colors ---
fvg_bull_css = color.new(#089981, 70)
fvg_bear_css = color.new(#f23645, 70)

// --- Types ---

type fvg_data
    float max
    float min
    bool  isbull
    int   t = time
    int   bar_born = 0
    int   touches = 0

// --- Detection Function ---

fvg_detect() =>
    var new_fvg = fvg_data.new(na, na, false, na)
    threshold = fvg_auto_threshold ? ta.cum((high - low) / low) / bar_index : fvg_threshold_pct / 100

    bull_fvg = low > high[2] and close[1] > high[2] and (low - high[2]) / high[2] > threshold
    bear_fvg = high < low[2] and close[1] < low[2] and (low[2] - high) / high > threshold

    if bull_fvg
        new_fvg := fvg_data.new(low, high[2], true)
    else if bear_fvg
        new_fvg := fvg_data.new(low[2], high, false)

    [bull_fvg, bear_fvg, new_fvg]

// --- Variables ---

var float fvg_max_bull = na, var float fvg_min_bull = na, var int fvg_bull_count = 0, var int fvg_bull_mitigated = 0
var float fvg_max_bear = na, var float fvg_min_bear = na, var int fvg_bear_count = 0, var int fvg_bear_mitigated = 0
var int fvg_last_t = 0

var fvg_records = array.new<fvg_data>(0)
var fvg_areas = array.new<box>(0)

// --- Shared state for confluence/entry ---
fvg_has_active_bull = false
fvg_has_active_bear = false
fvg_active_bull_top = float(na)
fvg_active_bull_btm = float(na)
fvg_active_bear_top = float(na)
fvg_active_bear_btm = float(na)
var int fvg_active_bar_born = 0
var int fvg_active_touches = 0

// --- Detection ---

[fvg_is_bull, fvg_is_bear, fvg_new] = request.security(syminfo.tickerid, fvg_tf, fvg_detect())

// Bull FVG
if show_fvg and fvg_is_bull and fvg_new.t != fvg_last_t
    fvg_areas.unshift(box.new(bar_index - 2, fvg_new.max, bar_index + FVG_EXTEND, fvg_new.min, na, bgcolor=fvg_bull_css))
    fvg_new.bar_born := bar_index
    fvg_records.unshift(fvg_new)
    fvg_bull_count += 1
    fvg_last_t := fvg_new.t

// Bear FVG
if show_fvg and fvg_is_bear and fvg_new.t != fvg_last_t
    fvg_areas.unshift(box.new(bar_index - 2, fvg_new.max, bar_index + FVG_EXTEND, fvg_new.min, na, bgcolor=fvg_bear_css))
    fvg_new.bar_born := bar_index
    fvg_records.unshift(fvg_new)
    fvg_bear_count += 1
    fvg_last_t := fvg_new.t

// --- Mitigation Detection ---

alert_fvg_bull_break = false
alert_fvg_bear_break = false

if fvg_records.size() > 0
    for i = fvg_records.size() - 1 to 0
        get_fvg = fvg_records.get(i)

        if get_fvg.isbull
            if close < get_fvg.min
                if fvg_mitigation_levels
                    line.new(get_fvg.t, get_fvg.min, time, get_fvg.min, xloc.bar_time, color=fvg_bull_css, style=line.style_dashed)

                area = fvg_areas.remove(i)
                area.delete()
                fvg_records.remove(i)
                fvg_bull_mitigated += 1
                alert_fvg_bull_break := true
            else
                fvg_in_zone = low <= get_fvg.max and close > get_fvg.min
                fvg_was_outside = low[1] > get_fvg.max
                if fvg_in_zone and fvg_was_outside
                    get_fvg.touches += 1
                if not fvg_has_active_bull
                    fvg_has_active_bull := true
                    fvg_active_bull_top := get_fvg.max
                    fvg_active_bull_btm := get_fvg.min
                    fvg_active_bar_born := get_fvg.bar_born
                    fvg_active_touches := get_fvg.touches
        else
            if close > get_fvg.max
                if fvg_mitigation_levels
                    line.new(get_fvg.t, get_fvg.max, time, get_fvg.max, xloc.bar_time, color=fvg_bear_css, style=line.style_dashed)

                area = fvg_areas.remove(i)
                area.delete()
                fvg_records.remove(i)
                fvg_bear_mitigated += 1
                alert_fvg_bear_break := true
            else
                fvg_in_zone = high >= get_fvg.min and close < get_fvg.max
                fvg_was_outside = high[1] < get_fvg.min
                if fvg_in_zone and fvg_was_outside
                    get_fvg.touches += 1
                if not fvg_has_active_bear
                    fvg_has_active_bear := true
                    fvg_active_bear_top := get_fvg.max
                    fvg_active_bear_btm := get_fvg.min
                    fvg_active_bar_born := get_fvg.bar_born
                    fvg_active_touches := get_fvg.touches

// --- Unmitigated Lines ---

var fvg_unmitigated = array.new<line>(0)

if barstate.islast and fvg_show_last > 0 and fvg_records.size() > 0
    if fvg_unmitigated.size() > 0
        for element in fvg_unmitigated
            element.delete()
        fvg_unmitigated.clear()

    for i = 0 to math.min(fvg_show_last - 1, fvg_records.size() - 1)
        get_fvg = fvg_records.get(i)
        fvg_unmitigated.push(line.new(get_fvg.t, get_fvg.isbull ? get_fvg.min : get_fvg.max, time, get_fvg.isbull ? get_fvg.min : get_fvg.max, xloc.bar_time, color=get_fvg.isbull ? fvg_bull_css : fvg_bear_css))

// ============================================================================
//                     MODULE: LIQUIDITY SWINGS
// ============================================================================

// --- Settings ---

liq_swing_length = input.int(3, "Pivot Length", minval=3, maxval=50, group="Liquidity Swings", tooltip="Lookback bars for detecting swing pivots used as liquidity levels")
liq_topCss       = input.color(#f7525f, "Swing High", inline="liq_top", group='Liquidity Swings')
liq_topAreaCss   = input.color(color.new(#f7525f, 50), "Area", inline="liq_top", group='Liquidity Swings')
liq_btmCss       = input.color(#22ab94, "Swing Low", inline="liq_btm", group='Liquidity Swings')
liq_btmAreaCss   = input.color(color.new(#22ab94, 50), "Area", inline="liq_btm", group='Liquidity Swings')
liq_labelSize    = 'Tiny'  // Label size for sweep volume labels

// --- Variables ---

var float liq_ph_top = na
var float liq_ph_btm = na
var bool  liq_ph_crossed = false
var int   liq_ph_x1 = 0
var box   liq_ph_bx = box.new(na, na, na, na
  , bgcolor = color.new(liq_topAreaCss, 80)
  , border_color = na)

var float liq_pl_top = na
var float liq_pl_btm = na
var bool  liq_pl_crossed = false
var int   liq_pl_x1 = 0
var box   liq_pl_bx = box.new(na, na, na, na
  , bgcolor = color.new(liq_btmAreaCss, 80)
  , border_color = na)

// --- Functions ---

liq_get_counts(bool is_pivot, float top, float btm) =>
    var count = 0
    var vol = 0.
    if is_pivot
        count := 0
        vol := 0.
    else
        vol += low[liq_swing_length] < top and high[liq_swing_length] > btm ? volume[liq_swing_length] : 0
        count += low[liq_swing_length] < top and high[liq_swing_length] > btm ? 1 : 0
    [count, vol]

liq_set_label(count, vol, x, y, css, lbl_style) =>
    var label lbl = na
    var lbl_size = f_getLabelSize(liq_labelSize)
    if ta.crossover(count, 0)
        label.delete(lbl)
        lbl := label.new(x, y, str.tostring(vol, format.volume)
          , style = lbl_style
          , size = lbl_size
          , color = COLOR_TRANSPARENT
          , textcolor = color.new(css, 100))
    if count > 0
        label.set_text(lbl, str.tostring(vol, format.volume))

liq_set_level(bool is_pivot, bool crossed, float value, count, css) =>
    var line lvl = na
    if is_pivot
        if count[1] < 0
            line.delete(lvl[1])
        else if not crossed[1]
            line.set_x2(lvl, bar_index - liq_swing_length)
        line.delete(lvl)
        lvl := line.new(bar_index - liq_swing_length, value, bar_index, value, color = na)
    if not crossed[1]
        line.set_x2(lvl, bar_index + 3)
    if crossed and not crossed[1]
        line.set_x2(lvl, bar_index)
        line.set_style(lvl, line.style_dashed)
    if count > 0
        line.set_color(lvl, css)

liq_set_zone(bool is_pivot, int x, float top, float btm, count, css) =>
    var box bx = na
    if ta.crossover(count, 0)
        box.delete(bx)
        bx := box.new(x, top, x + count, btm
          , border_color = na
          , bgcolor = css)
    if count > 0
        box.set_right(bx, x + count)

// --- Execution ---

liq_ph = ta.pivothigh(liq_swing_length, liq_swing_length)
liq_pl = ta.pivotlow(liq_swing_length, liq_swing_length)

// Pivot high counts
[liq_ph_count, liq_ph_vol] = liq_get_counts(not na(liq_ph), liq_ph_top, liq_ph_btm)

// Pivot high data update
if show_liq
    if not na(liq_ph)
        liq_ph_top := high[liq_swing_length]
        liq_ph_btm := math.max(close[liq_swing_length], open[liq_swing_length])
        liq_ph_x1 := bar_index - liq_swing_length
        liq_ph_crossed := false
    else
        liq_ph_crossed := close > liq_ph_top ? true : liq_ph_crossed

// Pivot high display (only when liq enabled)
if show_liq
    if not na(liq_ph)
        box.set_lefttop(liq_ph_bx, liq_ph_x1, liq_ph_top)
        box.set_rightbottom(liq_ph_bx, liq_ph_x1, liq_ph_btm)
    else
        if liq_ph_crossed
            box.set_right(liq_ph_bx, liq_ph_x1)
        else
            box.set_right(liq_ph_bx, bar_index + 3)

    liq_set_zone(not na(liq_ph), liq_ph_x1, liq_ph_top, liq_ph_btm, liq_ph_count, liq_topAreaCss)
    liq_set_level(not na(liq_ph), liq_ph_crossed, liq_ph_top, liq_ph_count, liq_topCss)
    liq_set_label(liq_ph_count, liq_ph_vol, liq_ph_x1, liq_ph_top, liq_topCss, label.style_label_down)

// Pivot low counts
[liq_pl_count, liq_pl_vol] = liq_get_counts(not na(liq_pl), liq_pl_top, liq_pl_btm)

// Pivot low data update
if show_liq
    if not na(liq_pl)
        liq_pl_top := math.min(close[liq_swing_length], open[liq_swing_length])
        liq_pl_btm := low[liq_swing_length]
        liq_pl_x1 := bar_index - liq_swing_length
        liq_pl_crossed := false
    else
        liq_pl_crossed := close < liq_pl_btm ? true : liq_pl_crossed

// Pivot low display (only when liq enabled)
if show_liq
    if not na(liq_pl)
        box.set_lefttop(liq_pl_bx, liq_pl_x1, liq_pl_top)
        box.set_rightbottom(liq_pl_bx, liq_pl_x1, liq_pl_btm)
    else
        if liq_pl_crossed
            box.set_right(liq_pl_bx, liq_pl_x1)
        else
            box.set_right(liq_pl_bx, bar_index + 3)

    liq_set_zone(not na(liq_pl), liq_pl_x1, liq_pl_top, liq_pl_btm, liq_pl_count, liq_btmAreaCss)
    liq_set_level(not na(liq_pl), liq_pl_crossed, liq_pl_btm, liq_pl_count, liq_btmCss)
    liq_set_label(liq_pl_count, liq_pl_vol, liq_pl_x1, liq_pl_btm, liq_btmCss, label.style_label_up)

// --- Sweep edge booleans (used by alerts) ---
alert_sweep_high = liq_ph_crossed and not liq_ph_crossed[1]
alert_sweep_low  = liq_pl_crossed and not liq_pl_crossed[1]

// ============================================================================
//                      MODULE: CANDLESTICK CHANNELS
// ============================================================================
// Pattern-based dynamic channels
// Patterns converge upper/lower bands on detection, creating trend channels

// --- Settings ---

cp_trend_length = 14   // Stochastic period for trend context
cp_atr_period   = 20   // ATR period for pattern body threshold

cp_show_hammer   = input.bool(true, "Hammer", group="Candlestick Patterns", tooltip="Bullish reversal - long lower wick, small body, appears in downtrend")
cp_show_ihammer  = input.bool(true, "Inverted Hammer", group="Candlestick Patterns", tooltip="Bullish reversal - long upper wick, small body, appears in downtrend")
cp_show_shooting = input.bool(true, "Shooting Star", group="Candlestick Patterns", tooltip="Bearish reversal - long upper wick, small body, appears in uptrend")
cp_show_hanging  = input.bool(true, "Hanging Man", group="Candlestick Patterns", tooltip="Bearish reversal - long lower wick, small body, appears in uptrend")
cp_show_bulleng  = input.bool(true, "Bullish Engulfing", group="Candlestick Patterns", tooltip="Bullish reversal - large green candle fully engulfs prior red candle")
cp_show_beareng  = input.bool(true, "Bearish Engulfing", group="Candlestick Patterns", tooltip="Bearish reversal - large red candle fully engulfs prior green candle")
cp_show_wm       = input.bool(true, "White Marubozu", group="Candlestick Patterns", tooltip="Strong bullish - large green candle with minimal wicks")
cp_show_bm       = input.bool(true, "Black Marubozu", group="Candlestick Patterns", tooltip="Strong bearish - large red candle with minimal wicks")

cp_bull_color = input.color(#22ab94, "Bullish Color", inline="cp_col", group="Candlestick Patterns")
cp_bear_color = input.color(#f7525f, "Bearish Color", inline="cp_col", group="Candlestick Patterns")

// --- Variables / Functions ---

cp_atr = ta.atr(cp_atr_period) / 2
cp_st = ta.stoch(close, close, close, cp_trend_length)
cp_downtrend = cp_st < 50
cp_uptrend = cp_st > 50

cp_d = math.abs(close - open)

cp_lbl(y, txt, direction, tlt) =>
    if show_candle_patterns
        label.new(bar_index, y, txt, size=size.tiny, style=direction == 1 ? label.style_label_up : label.style_label_down, color=direction == 1 ? cp_bull_color : cp_bear_color, textcolor=color.white, tooltip=tlt)

// --- Tooltips ---

var cp_hammer_tlt = "The hammer candlestick pattern is formed of a short body with a long lower wick, and is found at the bottom of a downward trend."
  + "\n" + "\nA hammer shows that although there were selling pressures during the day, ultimately a strong buying pressure drove the price back up."

var cp_ihammer_tlt = "The inverted hammer is a similar pattern than the hammer pattern. The only difference being that the upper wick is long, while the lower wick is short."
  + "\n" + "\nIt indicates a buying pressure, followed by a selling pressure that was not strong enough to drive the market price down. The inverse hammer suggests that buyers will soon have control of the market."

var cp_bulleng_tlt = "The bullish engulfing pattern is formed of two candlesticks. The first candle is a short red body that is completely engulfed by a larger green candle."
  + "\n" + "\nThough the second day opens lower than the first, the bullish market pushes the price up, culminating in an obvious win for buyers."

var cp_wm_tlt = "The white marubozu is a single candle formation formed after a downtrend and indicating a bullish reversal."
  + "\n" + "\nThis candlestick has a long bullish body with no upper or lower shadows, reflecting a strong buying pressure."

var cp_shooting_tlt = "The shooting star is the same shape as the inverted hammer, but is formed in an uptrend: it has a small lower body, and a long upper wick."
  + "\n" + "\nUsually, the market will gap slightly higher on opening and rally to an intra-day high before closing at a price just above the open - like a star falling to the ground."

var cp_hanging_tlt = "The hanging man is the bearish equivalent of a hammer; it has the same shape but forms at the end of an uptrend."
  + "\n" + "\nIt indicates that there was a significant sell-off during the day, but that buyers were able to push the price up again. The large sell-off is often seen as an indication that the bulls are losing control of the market."

var cp_beareng_tlt = "A bearish engulfing pattern occurs at the end of an uptrend. The first candle has a small green body that is engulfed by a subsequent long red candle."
  + "\n" + "\nIt signifies a peak or slowdown of price movement, and is a sign of an impending market downturn. The lower the second candle goes, the more significant the trend is likely to be."

var cp_bm_tlt = "The black marubozu is a single candle formation formed after an uptrend and indicating a bearish reversal."
  + "\n" + "\nThis candlestick has a long bearish body with no upper or lower shadows, reflecting a strong selling pressure."

// --- Pattern Rules ---

cp_hammer   = cp_downtrend and math.min(open, close) - low > 2 * cp_d and high - math.max(close, open) < cp_d / 4
cp_ihammer  = cp_downtrend and high - math.max(open, close) > 2 * cp_d and math.min(close, open) - low < cp_d / 4

cp_shooting = cp_uptrend and high - math.max(open, close) > 2 * cp_d and math.min(close, open) - low < cp_d / 4
cp_hanging  = cp_uptrend and math.min(open, close) - low > 2 * cp_d and high - math.max(close, open) < cp_d / 4

cp_bulleng  = cp_downtrend and close > open and close[1] < open[1] and close > open[1] and cp_d > cp_atr
cp_beareng  = cp_uptrend and close < open and close[1] > open[1] and close < open[1] and cp_d > cp_atr

cp_wm = close > open and high - math.max(open, close) + math.min(open, close) - low < cp_d / 10 and cp_d > cp_atr and cp_downtrend[1]
cp_bm = close < open and high - math.max(open, close) + math.min(open, close) - low < cp_d / 10 and cp_d > cp_atr and cp_uptrend[1]

// --- Channel Calculation ---

// Bullish Patterns
if cp_hammer and cp_show_hammer
    cp_lbl(low, "H", 1, cp_hammer_tlt)

if cp_ihammer and cp_show_ihammer
    cp_lbl(low, "IH", 1, cp_ihammer_tlt)

if cp_bulleng and cp_show_bulleng
    cp_lbl(low, "BE", 1, cp_bulleng_tlt)

if cp_wm and cp_show_wm
    cp_lbl(low, "WM", 1, cp_wm_tlt)

// Bearish Patterns
if cp_shooting and cp_show_shooting
    cp_lbl(high, "SS", 0, cp_shooting_tlt)

if cp_hanging and cp_show_hanging
    cp_lbl(high, "HM", 0, cp_hanging_tlt)

if cp_beareng and cp_show_beareng
    cp_lbl(high, "BE", 0, cp_beareng_tlt)

if cp_bm and cp_show_bm
    cp_lbl(high, "BM", 0, cp_bm_tlt)

// ============================================================================
//                       MODULE: MTF BIAS TABLE
// ============================================================================

// --- Settings ---

// --- CHoCH detection (Pivot approach, same as chart module) ---
// Pivot length 1. Close crossing swing high = bullish, swing low = bearish.

bias_choch() =>
    var int os = 0
    ph = ta.pivothigh(high, 1, 1)
    pl = ta.pivotlow(low, 1, 1)

    var float upper_val = na
    var bool  upper_crossed = false
    var float lower_val = na
    var bool  lower_crossed = false

    if not na(ph)
        upper_val := high[1]
        upper_crossed := false
    if not na(pl)
        lower_val := low[1]
        lower_crossed := false

    if ta.crossover(close, upper_val) and not upper_crossed
        os := 1
        upper_crossed := true
    if ta.crossunder(close, lower_val) and not lower_crossed
        os := -1
        lower_crossed := true

    os

// --- EMA alignment (EMA 50 vs EMA 100 & 200) ---

bias_ema() =>
    e1 = ta.ema(close, 50)
    e2 = ta.ema(close, 100)
    e3 = ta.ema(close, 200)
    e1 > e2 and e1 > e3 ? 1 : e1 < e2 and e1 < e3 ? -1 : 0

// --- Request each timeframe (consolidated: CHoCH + EMA in single call per TF) ---
// Uses [1] offset + lookahead_on for confirmed/closed HTF bar data.
// This ensures values are identical regardless of chart timeframe (non-repainting).

bias_combined_confirmed() =>
    choch = bias_choch()
    ema = bias_ema()
    [choch[1], ema[1]]

[bias_1h,  ema_1h]  = request.security(syminfo.tickerid, "60",  bias_combined_confirmed(), lookahead=barmerge.lookahead_on)
[bias_4h,  ema_4h]  = request.security(syminfo.tickerid, "240", bias_combined_confirmed(), lookahead=barmerge.lookahead_on)
[bias_d,   ema_d]   = request.security(syminfo.tickerid, "D",   bias_combined_confirmed(), lookahead=barmerge.lookahead_on)
[bias_w,   ema_w]   = request.security(syminfo.tickerid, "W",   bias_combined_confirmed(), lookahead=barmerge.lookahead_on)

bias_color(int b) => b == 1 ? COLOR_BULL : b == -1 ? COLOR_BEAR : COLOR_NEUTRAL

// ============================================================================
//                     MODULE: CONFLUENCE TABLE
// ============================================================================
// 7-factor confluence scoring + 4-factor entry checklist.
// Confluence: cross-TF CHoCH alignment (essential) + same-TF CHoCH+EMA match (nice-to-have)
// Entry: FVG zone, Equilibrium, Candle Pattern, LTF CHoCH
// All confluence factors on fixed timeframes. Entry uses min 1H for zones.

// --- Helper functions ---

conf_arrow(int val) => val == 1 ? "▲" : val == -1 ? "▼" : "-"

choch_tip(string tf, int b) =>
    b == 1 ? tf + ": Close broke above swing high" : b == -1 ? tf + ": Close broke below swing low" : tf + ": No change of character"

ema_tip(string tf, int b) =>
    b == 1 ? tf + ": EMA 50 above EMA 100 & 200" : b == -1 ? tf + ": EMA 50 below EMA 100 & 200" : tf + ": EMAs mixed"

conf_tbl_pos = switch conf_tbl_position
    "Top Right"    => position.top_right
    "Top Left"     => position.top_left
    "Bottom Right" => position.bottom_right
    "Bottom Left"  => position.bottom_left

conf_size = switch conf_tbl_size
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal

// --- Confluence Scoring (7 factors) ---

// Essential: Cross-TF CHoCH alignment (+1 each, max 3)
// Weekly has no row above, so it only gets nice-to-have
conf_wd_aligned  = bias_w != 0 and bias_d != 0 and bias_w == bias_d     // W→D aligned
conf_d4h_aligned = bias_d != 0 and bias_4h != 0 and bias_d == bias_4h   // D→4H aligned
conf_4h1h_aligned = bias_4h != 0 and bias_1h != 0 and bias_4h == bias_1h // 4H→1H aligned

// Nice-to-have: Same-TF CHoCH + EMA match (+1 each, max 4)
conf_w_match  = bias_w != 0 and ema_w != 0 and bias_w == ema_w
conf_d_match  = bias_d != 0 and ema_d != 0 and bias_d == ema_d
conf_4h_match = bias_4h != 0 and ema_4h != 0 and bias_4h == ema_4h
conf_1h_match = bias_1h != 0 and ema_1h != 0 and bias_1h == ema_1h

// Per-row scores
conf_w_score  = (conf_w_match ? 1 : 0)                                          // max 1
conf_d_score  = (conf_d_match ? 1 : 0) + (conf_wd_aligned ? 1 : 0)             // max 2
conf_4h_score = (conf_4h_match ? 1 : 0) + (conf_d4h_aligned ? 1 : 0)           // max 2
conf_1h_score = (conf_1h_match ? 1 : 0) + (conf_4h1h_aligned ? 1 : 0)          // max 2

// Total confluence score (max 7)
conf_score = conf_w_score + conf_d_score + conf_4h_score + conf_1h_score

// Direction: based on cross-TF alignment chain
// Count aligned directions
conf_bull_align = (conf_wd_aligned and bias_w == 1 ? 1 : 0) + (conf_d4h_aligned and bias_d == 1 ? 1 : 0) + (conf_4h1h_aligned and bias_4h == 1 ? 1 : 0)
conf_bear_align = (conf_wd_aligned and bias_w == -1 ? 1 : 0) + (conf_d4h_aligned and bias_d == -1 ? 1 : 0) + (conf_4h1h_aligned and bias_4h == -1 ? 1 : 0)
conf_direction = conf_bull_align > conf_bear_align ? 1 : conf_bear_align > conf_bull_align ? -1 : 0

conf_dir_text = conf_direction == 1 ? "LONG ▲" : conf_direction == -1 ? "SHORT ▼" : "NEUTRAL"
conf_dir_color = conf_direction == 1 ? COLOR_BULL : conf_direction == -1 ? COLOR_BEAR : COLOR_NEUTRAL

// --- FVG Entry Score (pure FVG quality, 0-4) ---

// Gate: is price inside an active FVG?
fvg_price_in_bull = fvg_has_active_bull and low <= fvg_active_bull_top and close > fvg_active_bull_btm
fvg_price_in_bear = fvg_has_active_bear and high >= fvg_active_bear_btm and close < fvg_active_bear_top
fvg_price_in_zone = fvg_price_in_bull or fvg_price_in_bear

// Factor 1: Fresh (formed within last 20 bars)
fvg_is_fresh = fvg_active_bar_born > 0 and (bar_index - fvg_active_bar_born) <= 20

// Factor 2: First touch (never tested before — touch count is 0 or 1 meaning current touch is the first)
fvg_is_first_touch = fvg_active_touches <= 1

// Factor 3: Higher TF (FVG timeframe is >= 1H)
// If fvg_tf is empty, it uses chart TF. Check if effective TF >= 60 minutes.
fvg_effective_tf = fvg_tf == "" ? timeframe.period : fvg_tf
fvg_is_htf = timeframe.in_seconds(fvg_effective_tf) >= timeframe.in_seconds("60")

// Factor 4: Deep fill (price reached >= 50% into the FVG zone)
fvg_zone_mid_bull = fvg_has_active_bull ? math.avg(fvg_active_bull_top, fvg_active_bull_btm) : na
fvg_zone_mid_bear = fvg_has_active_bear ? math.avg(fvg_active_bear_top, fvg_active_bear_btm) : na
fvg_deep_fill = (fvg_price_in_bull and not na(fvg_zone_mid_bull) and low <= fvg_zone_mid_bull) or (fvg_price_in_bear and not na(fvg_zone_mid_bear) and high >= fvg_zone_mid_bear)

// Pure FVG score (0-4, only counts when price is in zone)
fvg_score = fvg_price_in_zone ? (fvg_is_fresh ? 1 : 0) + (fvg_is_first_touch ? 1 : 0) + (fvg_is_htf ? 1 : 0) + (fvg_deep_fill ? 1 : 0) : 0

// Simple entry flag (for summary)
entry_at_fvg = fvg_price_in_zone

// Session label (no score) — fetched from 1m via request.security for accuracy on all TFs
conf_ses_detect() =>
    is_ny  = nz(time(timeframe.period, "1300-2200", syminfo.timezone)) > 0
    is_ldn = nz(time(timeframe.period, "0700-1600", syminfo.timezone)) > 0
    is_asia = nz(time(timeframe.period, "0000-0900", syminfo.timezone)) > 0
    [is_ny, is_ldn, is_asia]

[conf_is_ny, conf_is_ldn, conf_is_asia] = request.security(syminfo.tickerid, "1", conf_ses_detect())

conf_ses_text = conf_is_ny and conf_is_ldn ? "London / NY" : conf_is_ny ? "New York" : conf_is_ldn ? "London" : conf_is_asia ? "Asia" : "Off Hours"

// --- Table Drawing ---
var table conf_tbl = table.new(conf_tbl_pos, 4, 19, border_width=1, border_color=COLOR_TABLE_BORDER, bgcolor=COLOR_TABLE_BG, frame_width=1, frame_color=COLOR_TABLE_BORDER)

if show_confluence_table and barstate.islast
    int row = 0

    if conf_show_details
        // === CONFLUENCE SECTION TITLE ===
        int conf_title_row = row
        table.cell(conf_tbl, 0, conf_title_row, "CONFLUENCE", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, conf_title_row, "", bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 2, conf_title_row, "", bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 3, conf_title_row, "", bgcolor=COLOR_TABLE_BG)
        table.merge_cells(conf_tbl, 0, conf_title_row, 3, conf_title_row)
        row += 1

        // Header (4-column)
        table.cell(conf_tbl, 0, row, "",        text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, row, "CHoCH",   text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip="Change of Character - structure direction")
        table.cell(conf_tbl, 2, row, "EMA",     text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip="EMA 50/100/200 alignment")
        table.cell(conf_tbl, 3, row, "Score",   text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        row += 1

        // Weekly (max 1: match only)
        table.cell(conf_tbl, 0, row, "Weekly",  text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, row, conf_arrow(bias_w), text_color=bias_color(bias_w), text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=choch_tip("W", bias_w))
        table.cell(conf_tbl, 2, row, conf_arrow(ema_w),  text_color=bias_color(ema_w),  text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=ema_tip("W", ema_w))
        table.cell(conf_tbl, 3, row, str.tostring(conf_w_score) + "/1", text_color=conf_w_score > 0 ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        row += 1

        // Daily (max 2: match + W→D aligned)
        table.cell(conf_tbl, 0, row, "Daily",   text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, row, conf_arrow(bias_d), text_color=bias_color(bias_d), text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=choch_tip("D", bias_d))
        table.cell(conf_tbl, 2, row, conf_arrow(ema_d),  text_color=bias_color(ema_d),  text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=ema_tip("D", ema_d))
        table.cell(conf_tbl, 3, row, str.tostring(conf_d_score) + "/2", text_color=conf_d_score > 0 ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        row += 1

        // 4H (max 2: match + D→4H aligned)
        table.cell(conf_tbl, 0, row, "4H",      text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, row, conf_arrow(bias_4h), text_color=bias_color(bias_4h), text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=choch_tip("4H", bias_4h))
        table.cell(conf_tbl, 2, row, conf_arrow(ema_4h),  text_color=bias_color(ema_4h),  text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=ema_tip("4H", ema_4h))
        table.cell(conf_tbl, 3, row, str.tostring(conf_4h_score) + "/2", text_color=conf_4h_score > 0 ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        row += 1

        // 1H (max 2: match + 4H→1H aligned)
        table.cell(conf_tbl, 0, row, "1H",      text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, row, conf_arrow(bias_1h), text_color=bias_color(bias_1h), text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=choch_tip("1H", bias_1h))
        table.cell(conf_tbl, 2, row, conf_arrow(ema_1h),  text_color=bias_color(ema_1h),  text_size=conf_size, bgcolor=COLOR_TABLE_BG, tooltip=ema_tip("1H", ema_1h))
        table.cell(conf_tbl, 3, row, str.tostring(conf_1h_score) + "/2", text_color=conf_1h_score > 0 ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        row += 1

        // Session (full-width: label col 0, session text spans cols 1-3)
        int ses_row = row
        table.cell(conf_tbl, 0, ses_row, "Session", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, ses_row, conf_ses_text, text_color=(conf_is_ny or conf_is_ldn or conf_is_asia) ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 2, ses_row, "", bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 3, ses_row, "", bgcolor=COLOR_TABLE_BG)
        table.merge_cells(conf_tbl, 1, ses_row, 3, ses_row)
        row += 1

        // === ENTRY CHECKLIST === (full-width header)
        int entry_hdr_row = row
        table.cell(conf_tbl, 0, entry_hdr_row, "ENTRY", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, entry_hdr_row, "", bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 2, entry_hdr_row, "", bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 3, entry_hdr_row, "", bgcolor=COLOR_TABLE_BG)
        table.merge_cells(conf_tbl, 0, entry_hdr_row, 3, entry_hdr_row)
        row += 1

        // FVG quality score
        int fvg_row = row
        fvg_status = fvg_price_in_zone ? (fvg_is_htf ? "At HTF FVG" : "At FVG") : "Not yet"
        table.cell(conf_tbl, 0, fvg_row, "FVG Zone", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 1, fvg_row, fvg_status, text_color=fvg_price_in_zone ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 2, fvg_row, "", bgcolor=COLOR_TABLE_BG)
        table.cell(conf_tbl, 3, fvg_row, str.tostring(fvg_score) + "/4", text_color=fvg_score > 0 ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
        table.merge_cells(conf_tbl, 1, fvg_row, 2, fvg_row)
        row += 1

    // === SUMMARY SECTION TITLE ===
    int sum_title_row = row
    table.cell(conf_tbl, 0, sum_title_row, "SUMMARY", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 1, sum_title_row, "", bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 2, sum_title_row, "", bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 3, sum_title_row, "", bgcolor=COLOR_TABLE_BG)
    table.merge_cells(conf_tbl, 0, sum_title_row, 3, sum_title_row)
    row += 1

    // Confluence score
    int conf_row = row
    table.cell(conf_tbl, 0, conf_row, "Confluence", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 1, conf_row, str.tostring(conf_score) + "/7", text_color=conf_dir_color, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 2, conf_row, "", bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 3, conf_row, "", bgcolor=COLOR_TABLE_BG)
    table.merge_cells(conf_tbl, 1, conf_row, 3, conf_row)
    row += 1

    // Entry score (FVG-based)
    int ent_row = row
    table.cell(conf_tbl, 0, ent_row, "Entry", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 1, ent_row, str.tostring(fvg_score) + "/4", text_color=fvg_score > 0 ? COLOR_BULL : COLOR_NEUTRAL, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 2, ent_row, "", bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 3, ent_row, "", bgcolor=COLOR_TABLE_BG)
    table.merge_cells(conf_tbl, 1, ent_row, 3, ent_row)
    row += 1

    // Direction (last - the conclusion)
    int dir_row = row
    table.cell(conf_tbl, 0, dir_row, "Direction", text_color=color.white, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 1, dir_row, conf_dir_text, text_color=conf_dir_color, text_size=conf_size, bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 2, dir_row, "", bgcolor=COLOR_TABLE_BG)
    table.cell(conf_tbl, 3, dir_row, "", bgcolor=COLOR_TABLE_BG)
    table.merge_cells(conf_tbl, 1, dir_row, 3, dir_row)

// --- Alerts ---
conf_score_meets = conf_score >= conf_alert_threshold
alertcondition(conf_score_meets and not conf_score_meets[1], "Confluence Ready", "Nexus confluence score reached threshold")

// ============================================================================
//                              ALERTS
// ============================================================================
// Edge booleans: alert_sweep_high/low, alert_choch_bull/bear, alert_fvg_*_break
// are computed earlier in their respective modules and reused here.

// --- alertcondition() calls (static alerts for TradingView alert manager) ---
alertcondition(alert_sweep_high,  "Sweep High",   "Liquidity sweep: swing high crossed")
alertcondition(alert_sweep_low,   "Sweep Low",    "Liquidity sweep: swing low crossed")
alertcondition(alert_choch_bull,  "ChoCH Bullish", "Change of Character: bearish to bullish")
alertcondition(alert_choch_bear,  "ChoCH Bearish", "Change of Character: bullish to bearish")
alertcondition(alert_fvg_bull_break, "FVG Bull Broken", "Bullish FVG broken - price closed below gap")
alertcondition(alert_fvg_bear_break, "FVG Bear Broken", "Bearish FVG broken - price closed above gap")
